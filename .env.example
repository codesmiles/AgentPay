# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: your OpenAI API key (used by the AI reasoning engine)
OPENAI_API_KEY=sk-...

# Ethereum private key for the agent wallet (signs transactions + owns the escrow contract)
